# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Release signing properties (used for local production builds)
RELEASE_STORE_PASSWORD=your_keystore_password_here
RELEASE_KEY_PASSWORD=your_key_password_here

# Set to "true" to pre-populate sample data for testing without a GitHub PAT
DUMMY_DATA_ENABLED=false

